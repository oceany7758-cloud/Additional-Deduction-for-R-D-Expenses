/* ===== 摊销明细 ===== */
var amortData=[
  {id:"AM001",aid:"A001",period:"2026-01",beginNet:150000,cur:2500,accum:2500,endNet:147500,status:"已摊销"},
  {id:"AM002",aid:"A001",period:"2026-02",beginNet:147500,cur:2500,accum:5000,endNet:145000,status:"已摊销"},
  {id:"AM003",aid:"A001",period:"2026-03",beginNet:145000,cur:2500,accum:7500,endNet:142500,status:"待摊销"},
  {id:"AM004",aid:"A002",period:"2026-01",beginNet:380000,cur:3016,accum:3016,endNet:376984,status:"已摊销"},
  {id:"AM005",aid:"A002",period:"2026-02",beginNet:376984,cur:3016,accum:6032,endNet:373968,status:"待摊销"}
];

var currentAmortAsset=null;

function viewAmortDetail(assetId){
  var asset=null;
  for(var i=0;i<assetData.length;i++){
    if(assetData[i].id===assetId){asset=assetData[i];break}
  }
  if(!asset){alert('资产不存在');return;}
  currentAmortAsset=asset;
  
  document.getElementById('amortDetailTitle').textContent='摊销明细 — '+asset.name;
  document.getElementById('ad_aid').value=asset.id;
  document.getElementById('ad_aname').value=asset.name;
  document.getElementById('ad_deduction').value=fmt(asset.orig);
  document.getElementById('ad_res').value=asset.res+'%';
  document.getElementById('ad_tlife').value=asset.life*12+'个月';
  document.getElementById('ad_meth').value=asset.meth;
  
  renderAmortDetail(assetId);
  openMo('moAmortDetail');
}

function renderAmortDetail(assetId){
  var list=amortData.filter(function(a){return a.aid===assetId});
  list.sort(function(a,b){return a.period>b.period?1:-1});
  
  var h='';
  for(var i=0;i<list.length;i++){
    var a=list[i];
    var statusTag=a.status==='已摊销'?'<span class="t t-g">'+a.status+'</span>':'<span class="t t-y">'+a.status+'</span>';
    h+='<tr><td>'+a.period+'</td><td style="text-align:right">'+fmt(a.beginNet)+'</td><td style="text-align:right">'+fmt(a.cur)+'</td><td style="text-align:right">'+fmt(a.accum)+'</td><td style="text-align:right">'+fmt(a.endNet)+'</td><td>'+statusTag+'</td><td>';
    if(a.status==='待摊销'){
      h+='<button class="btn btn-sm btn-p" onclick="markAmortDone(\''+a.id+'\')">标记已摊销</button>';
    }else{
      h+='<span style="color:var(--g400)">—</span>';
    }
    h+='</td></tr>';
  }
  
  if(!list.length){
    h='<tr><td colspan="7" style="text-align:center;color:var(--g400);padding:20px">暂无摊销记录，请点击"生成下一期摊销"创建</td></tr>';
  }
  
  document.getElementById('amortDetailTb').innerHTML=h;
}

function markAmortDone(id){
  for(var i=0;i<amortData.length;i++){
    if(amortData[i].id===id){
      amortData[i].status='已摊销';
      break;
    }
  }
  if(currentAmortAsset){
    renderAmortDetail(currentAmortAsset.id);
  }
  alert('已标记为已摊销');
}

function calcAmortAmount(deduction,res,tlife,method){
  var depreciable=deduction*(1-res/100);
  if(method==='直线法'){
    return Math.round(depreciable/tlife);
  }else if(method==='双倍余额递减法'){
    var rate=2/tlife;
    return Math.round(deduction*rate);
  }else if(method==='年数总和法'){
    var sum=tlife*(tlife+1)/2;
    return Math.round(depreciable*tlife/sum/tlife);
  }
  return Math.round(depreciable/tlife);
}

function genNextAmort(){
  if(!currentAmortAsset){return;}
  var asset=currentAmortAsset;
  var deduction=asset.orig;
  var res=asset.res;
  var tlife=asset.life*12;
  var meth=asset.meth;
  
  var list=amortData.filter(function(a){return a.aid===asset.id});
  list.sort(function(a,b){return a.period>b.period?1:-1});
  
  var nextPeriod='';
  var lastEndNet=deduction;
  
  if(list.length>0){
    var last=list[list.length-1];
    var parts=last.period.split('-');
    var y=parseInt(parts[0]),m=parseInt(parts[1])+1;
    if(m>12){m=1;y++}
    nextPeriod=y+'-'+(m<10?'0'+m:m);
    lastEndNet=last.endNet;
  }else{
    var now=new Date();
    nextPeriod=now.getFullYear()+'-'+(now.getMonth()+1<10?'0'+(now.getMonth()+1):now.getMonth()+1);
  }
  
  var curAmort=calcAmortAmount(deduction,res,tlife,meth);
  var accum=0;
  for(var i=0;i<list.length;i++){accum+=list[i].cur;}
  var newAccum=accum+curAmort;
  var newEndNet=deduction*(1-res/100)-newAccum;
  if(newEndNet<0)newEndNet=0;
  
  var existIdx=-1;
  for(var i=0;i<amortData.length;i++){
    if(amortData[i].aid===asset.id&&amortData[i].period===nextPeriod){existIdx=i;break}
  }
  
  var rec={
    id:'AM'+(amortData.length+1).toString().padStart(3,'0'),
    aid:asset.id,
    period:nextPeriod,
    beginNet:lastEndNet,
    cur:curAmort,
    accum:newAccum,
    endNet:newEndNet,
    status:'待摊销'
  };
  
  if(existIdx>=0){
    amortData[existIdx]=rec;
  }else{
    amortData.push(rec);
  }
  
  renderAmortDetail(asset.id);
  alert('已生成 '+nextPeriod+' 期摊销记录');
}

function genAllAmort(){
  if(!currentAmortAsset){return;}
  var asset=currentAmortAsset;
  var deduction=asset.orig;
  var res=asset.res;
  var tlife=asset.life*12;
  var meth=asset.meth;
  
  var list=amortData.filter(function(a){return a.aid===asset.id});
  if(list.length>=tlife){
    alert('该资产已生成全部'+tlife+'期摊销计划');
    return;
  }
  
  var existPeriods={};
  for(var i=0;i<list.length;i++){existPeriods[list[i].period]=true;}
  
  var startYear,startMonth;
  if(list.length>0){
    var last=list[list.length-1];
    var parts=last.period.split('-');
    startYear=parseInt(parts[0]);
    startMonth=parseInt(parts[1])+1;
    if(startMonth>12){startMonth=1;startYear++}
  }else{
    var now=new Date();
    startYear=now.getFullYear();
    startMonth=now.getMonth()+1;
  }
  
  var accum=0;
  for(var i=0;i<list.length;i++){accum+=list[i].cur;}
  
  var count=0;
  var curYear=startYear,curMonth=startMonth;
  
  for(var i=0;i<tlife-list.length;i++){
    var period=curYear+'-'+(curMonth<10?'0'+curMonth:curMonth);
    if(!existPeriods[period]){
      var curAmort=calcAmortAmount(deduction,res,tlife,meth);
      var beginNet=deduction*(1-res/100)-accum;
      accum+=curAmort;
      var endNet=deduction*(1-res/100)-accum;
      if(endNet<0)endNet=0;
      
      amortData.push({
        id:'AM'+(amortData.length+1).toString().padStart(3,'0'),
        aid:asset.id,
        period:period,
        beginNet:beginNet,
        cur:curAmort,
        accum:accum,
        endNet:endNet,
        status:'待摊销'
      });
      count++;
    }
    
    curMonth++;
    if(curMonth>12){curMonth=1;curYear++}
  }
  
  renderAmortDetail(asset.id);
  alert('已生成全部摊销计划，共 '+count+' 条记录');
}

function saveTransfer(){
  var id=document.getElementById('ft_id').value;
  var name=document.getElementById('ft_name').value;
  var l1=document.getElementById('ft_l1').value;
  var l2=document.getElementById('ft_l2').value;
  var deduction=document.getElementById('ft_deduction').value;
  
  if(!id||!name||!l1||!l2||!deduction){
    alert('请填写所有必填字段');
    return;
  }
  
  assetData.push({
    id:id,
    name:name,
    spec:document.getElementById('ft_spec').value,
    l1:l1,
    l2:l2,
    obtain:'自研',
    proj:document.getElementById('ft_proj').value,
    company:document.getElementById('ft_company').value,
    dept:document.getElementById('ft_dept').value,
    use:document.getElementById('ft_use').value||'在用',
    orig:parseFloat(document.getElementById('ft_orig').value)||parseFloat(deduction),
    res:parseFloat(document.getElementById('ft_res').value)||5,
    life:Math.ceil((parseFloat(document.getElementById('ft_tlife').value)||60)/12)||5,
    meth:document.getElementById('ft_meth').value||'直线法',
    date:document.getElementById('ft_date').value,
    diff:document.getElementById('ft_diff').value,
    purpose:document.getElementById('ft_purpose').value||'直接研发',
    rmk:document.getElementById('ft_rmk').value
  });
  
  renderAsset(assetData);
  // Also add to amortPageData for 摊销管理 page
  amortPageData.push({
    proj:document.getElementById('ft_proj').value,
    aid:id,
    name:name,
    spec:document.getElementById('ft_spec').value,
    l1:l1,
    l2:l2,
    dept:document.getElementById('ft_dept').value,
    use:document.getElementById('ft_use').value||'在用',
    date:document.getElementById('ft_date').value,
    tlife:parseInt(document.getElementById('ft_tlife').value)||60,
    orig:parseFloat(document.getElementById('ft_orig').value)||parseFloat(deduction),
    deduction:parseFloat(deduction),
    res:parseFloat(document.getElementById('ft_res').value)||5,
    meth:document.getElementById('ft_meth').value||'直线法',
    rmk:document.getElementById('ft_rmk').value
  });
  renderAmort(amortPageData);
  closeMo('moTransfer');
  alert('资产已保存至资产信息和摊销管理模块');
}

