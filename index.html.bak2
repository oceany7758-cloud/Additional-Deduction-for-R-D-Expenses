var projPersons=[], projAssets=[], projOrgs=[], projArchs=[];

function renderPersonRows(){
  var h='';
  for(var i=0;i<projPersons.length;i++){
    var p=projPersons[i];
    h+='<tr><td>'+p.id+'</td><td>'+p.name+'</td><td>'+p.major+'</td><td>'+p.title+'</td><td>'+p.utype+'</td><td>'+p.role+'</td><td>'+p.start+'</td><td>'+(p.end||'—')+'</td><td><span class="del-row" onclick="delRow(\'person\','+i+')">删除</span></td></tr>';
  }
  document.getElementById('projPersonRows').innerHTML=h;
}
function renderAssetRows(){
  var h='';
  for(var i=0;i<projAssets.length;i++){
    var a=projAssets[i];
    h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.l1+'-'+a.l2+'</td><td>'+a.purpose+'</td><td><span class="del-row" onclick="delRow(\'asset\','+i+')">删除</span></td></tr>';
  }
  document.getElementById('projAssetRows').innerHTML=h;
}
function renderOrgRows(){
  var h='';
  for(var i=0;i<projOrgs.length;i++){
    var o=projOrgs[i];
    h+='<tr><td>'+o.id+'</td><td>'+o.name+'</td><td>'+o.type+'</td><td>'+o.rel+'</td><td><span class="del-row" onclick="delRow(\'org\','+i+')">删除</span></td></tr>';
  }
  document.getElementById('projOrgRows').innerHTML=h;
}
function renderArchRows(){
  var h='';
  for(var i=0;i<projArchs.length;i++){
    var a=projArchs[i];
    h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.big+'-'+a.small+'</td><td>'+a.date+'</td><td><span class="del-row" onclick="delRow(\'arch\','+i+')">删除</span></td></tr>';
  }
  document.getElementById('projArchRows').innerHTML=h;
}
function delRow(type,idx){
  if(type==='person'){projPersons.splice(idx,1);renderPersonRows()}
  else if(type==='asset'){projAssets.splice(idx,1);renderAssetRows()}
  else if(type==='org'){projOrgs.splice(idx,1);renderOrgRows()}
  else if(type==='arch'){projArchs.splice(idx,1);renderArchRows()}
}

/* ===== Picker: 打开选择弹窗并渲染列表 ===== */
var pendingPersonSetup=null;
function openPicker(type){
  if(type==='personPicker'){
    var tb=document.getElementById('pp_tb');var h='';
    for(var i=0;i<personData.length;i++){
      var p=personData[i];
      h+='<tr><td>'+p.id+'</td><td>'+p.name+'</td><td>'+p.major+'</td><td>'+p.title+'</td><td>'+p.utype+'</td><td><button class="btn btn-sm btn-p" onclick="pickPerson(\''+p.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;openMo('personPicker');
  } else if(type==='assetPicker'){
    var tb=document.getElementById('ap_tb');var h='';
    for(var i=0;i<assetData.length;i++){
      var a=assetData[i];
      h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.l1+'-'+a.l2+'</td><td>'+a.purpose+'</td><td><button class="btn btn-sm btn-p" onclick="pickAsset(\''+a.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;openMo('assetPicker');
  } else if(type==='orgPicker'){
    var tb=document.getElementById('op_tb');var h='';
    for(var i=0;i<orgData.length;i++){
      var o=orgData[i];
      h+='<tr><td>'+o.id+'</td><td>'+o.name+'</td><td>'+o.type+'</td><td>'+o.rel+'</td><td><button class="btn btn-sm btn-p" onclick="pickOrg(\''+o.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;openMo('orgPicker');
  } else if(type==='archPicker'){
    var tb=document.getElementById('arp_tb');var h='';
    for(var i=0;i<archData.length;i++){
      var a=archData[i];
      h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.big+'-'+a.small+'</td><td>'+a.date+'</td><td><button class="btn btn-sm btn-p" onclick="pickArch(\''+a.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;openMo('archPicker');
  }
}

function pickPerson(id){
  closeMo('personPicker');
  var p=null;for(var i=0;i<personData.length;i++){if(personData[i].id===id){p=personData[i];break}}
  if(!p)return;
  pendingPersonSetup={id:p.id,name:p.name,major:p.major,title:p.title,utype:p.utype};
  document.getElementById('ps_id').value=p.id;
  document.getElementById('ps_name').value=p.name;
  document.getElementById('ps_role').value='';document.getElementById('ps_start').value='';document.getElementById('ps_end').value='';
  openMo('personSetup');
}
function confirmPersonSetup(){
  var role=document.getElementById('ps_role').value,start=document.getElementById('ps_start').value;
  if(!role||!start){alert('请填写研发分工和参与项目起');return;}
  var item={id:pendingPersonSetup.id,name:pendingPersonSetup.name,major:pendingPersonSetup.major,title:pendingPersonSetup.title,utype:pendingPersonSetup.utype,role:role,start:start,end:document.getElementById('ps_end').value};
  projPersons.push(item);renderPersonRows();closeMo('personSetup');
}
function pickAsset(id){
  closeMo('assetPicker');
  var a=null;for(var i=0;i<assetData.length;i++){if(assetData[i].id===id){a=assetData[i];break}}
  if(!a)return;
  projAssets.push({id:a.id,name:a.name,l1:a.l1,l2:a.l2,purpose:a.purpose});renderAssetRows();
}
function pickOrg(id){
  closeMo('orgPicker');
  var o=null;for(var i=0;i<orgData.length;i++){if(orgData[i].id===id){o=orgData[i];break}}
  if(!o)return;
  projOrgs.push({id:o.id,name:o.name,type:o.type,rel:o.rel});renderOrgRows();
}
function pickArch(id){
  closeMo('archPicker');
  var a=null;for(var i=0;i<archData.length;i++){if(archData[i].id===id){a=archData[i];break}}
  if(!a)return;
  projArchs.push({id:a.id,name:a.name,big:a.big,small:a.small,date:a.date});renderArchRows();
}

function filterPicker(type){
  if(type==='person'){
    var q=document.getElementById('pp_search').value.toLowerCase();
    var filtered=personData.filter(function(p){return p.id.toLowerCase().indexOf(q)>=0||p.name.indexOf(q)>=0});
    var tb=document.getElementById('pp_tb');var h='';
    for(var i=0;i<filtered.length;i++){
      var p=filtered[i];
      h+='<tr><td>'+p.id+'</td><td>'+p.name+'</td><td>'+p.major+'</td><td>'+p.title+'</td><td>'+p.utype+'</td><td><button class="btn btn-sm btn-p" onclick="pickPerson(\''+p.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;
  } else if(type==='asset'){
    var q=document.getElementById('ap_search').value.toLowerCase();
    var filtered=assetData.filter(function(a){return a.id.toLowerCase().indexOf(q)>=0||a.name.indexOf(q)>=0});
    var tb=document.getElementById('ap_tb');var h='';
    for(var i=0;i<filtered.length;i++){
      var a=filtered[i];
      h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.l1+'-'+a.l2+'</td><td>'+a.purpose+'</td><td><button class="btn btn-sm btn-p" onclick="pickAsset(\''+a.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;
  } else if(type==='org'){
    var q=document.getElementById('op_search').value.toLowerCase();
    var filtered=orgData.filter(function(o){return o.id.toLowerCase().indexOf(q)>=0||o.name.indexOf(q)>=0});
    var tb=document.getElementById('op_tb');var h='';
    for(var i=0;i<filtered.length;i++){
      var o=filtered[i];
      h+='<tr><td>'+o.id+'</td><td>'+o.name+'</td><td>'+o.type+'</td><td>'+o.rel+'</td><td><button class="btn btn-sm btn-p" onclick="pickOrg(\''+o.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;
  } else if(type==='arch'){
    var q=document.getElementById('arp_search').value.toLowerCase();
    var filtered=archData.filter(function(a){return a.id.toLowerCase().indexOf(q)>=0||a.name.indexOf(q)>=0});
    var tb=document.getElementById('arp_tb');var h='';
    for(var i=0;i<filtered.length;i++){
      var a=filtered[i];
      h+='<tr><td>'+a.id+'</td><td>'+a.name+'</td><td>'+a.big+'-'+a.small+'</td><td>'+a.date+'</td><td><button class="btn btn-sm btn-p" onclick="pickArch(\''+a.id+'\')">选择</button></td></tr>';
    }
    tb.innerHTML=h;
  }
}

/* backup openProj binding */
document.addEventListener('DOMContentLoaded',function(){
  var btn=document.querySelector('[onclick="openProj()"]');
  if(btn){btn.addEventListener('click',function(e){e.preventDefault();openProj()});}
});



function viewAmortDetailFromPage(aid){viewAmortDetail(aid)}
</script>

<!-- 人员选择弹窗 -->
<div class="mo" id="personPicker"><div class="ml" style="max-width:800px">
<div class="ml-h"><h3>选择研发人员</h3><button class="ml-x" onclick="closeMo('personPicker')">✕</button></div>
<div class="ml-b">
<div class="qf" style="margin-bottom:12px"><div class="fg"><label>搜索</label><input id="pp_search" placeholder="工号/姓名" oninput="filterPicker('person')"></div></div>
<table><thead><tr><th>工号</th><th>姓名</th><th>专业</th><th>职称名称</th><th>用工类别</th><th>操作</th></tr></thead><tbody id="pp_tb"></tbody></table>
</div></div></div>

<!-- 人员设置弹窗（研发分工等） -->
<div class="mo" id="personSetup"><div class="ml" style="max-width:500px">
<div class="ml-h"><h3>设置参与信息</h3><button class="ml-x" onclick="closeMo('personSetup')">✕</button></div>
<div class="ml-b">
<div class="fg2">
<div class="fg"><label>工号</label><input id="ps_id" readonly class="ro-green"></div>
<div class="fg"><label>姓名</label><input id="ps_name" readonly class="ro-green"></div>
<div class="fg"><label><span class="req">*</span>研发分工</label><select id="ps_role"><option value="">请选择</option><option>研究</option><option>技术</option><option>辅助</option><option>管理</option><option>服务</option><option>其他</option></select></div>
<div class="fg"><label><span class="req">*</span>参与项目起</label><input type="date" id="ps_start"></div>
<div class="fg"><label>参与项目止</label><input type="date" id="ps_end"></div>
</div></div>
<div class="ml-f"><button class="btn btn-o" onclick="closeMo('personSetup')">取消</button><button class="btn btn-p" onclick="confirmPersonSetup()">确认</button></div>
</div></div>

<!-- 资产选择弹窗 -->
<div class="mo" id="assetPicker"><div class="ml" style="max-width:800px">
<div class="ml-h"><h3>选择研发资产</h3><button class="ml-x" onclick="closeMo('assetPicker')">✕</button></div>
<div class="ml-b">
<div class="qf" style="margin-bottom:12px"><div class="fg"><label>搜索</label><input id="ap_search" placeholder="资产编号/名称" oninput="filterPicker('asset')"></div></div>
<table><thead><tr><th>资产编号</th><th>资产名称</th><th>资产类别</th><th>用途分类</th><th>操作</th></tr></thead><tbody id="ap_tb"></tbody></table>
</div></div></div>

<!-- 组织选择弹窗 -->
<div class="mo" id="orgPicker"><div class="ml" style="max-width:800px">
<div class="ml-h"><h3>选择研发组织</h3><button class="ml-x" onclick="closeMo('orgPicker')">✕</button></div>
<div class="ml-b">
<div class="qf" style="margin-bottom:12px"><div class="fg"><label>搜索</label><input id="op_search" placeholder="组织编号/名称" oninput="filterPicker('org')"></div></div>
<table><thead><tr><th>组织编号</th><th>组织名称</th><th>组织类型</th><th>关联关系</th><th>操作</th></tr></thead><tbody id="op_tb"></tbody></table>
</div></div></div>

<!-- 档案选择弹窗 -->
<div class="mo" id="archPicker"><div class="ml" style="max-width:800px">
<div class="ml-h"><h3>选择项目档案</h3><button class="ml-x" onclick="closeMo('archPicker')">✕</button></div>
<div class="ml-b">
<div class="qf" style="margin-bottom:12px"><div class="fg"><label>搜索</label><input id="arp_search" placeholder="档案编号/名称" oninput="filterPicker('arch')"></div></div>
<table><thead><tr><th>档案编号</th><th>档案名称</th><th>档案类别</th><th>档案日期</th><th>操作</th></tr></thead><tbody id="arp_tb"></tbody></table>
</div></div></div>

<!-- 资本化结转弹窗 -->
<div class="mo" id="moTransfer"><div class="ml" style="max-width:900px">
<div class="ml-h"><h3 id="transferTitle">资本化结转 — 新增资产</h3><button class="ml-x" onclick="closeMo('moTransfer')">✕</button></div>
<div class="ml-b">
<div class="rc">根据项目资本化阶段的辅助账数据，将研发支出结转为无形资产。系统将自动计算加计扣除原值。</div>
<div class="sec">资产信息</div><div class="fg2">
<div class="fg"><label><span class="req">*</span>资产编号</label><input id="ft_id"></div>
<div class="fg"><label><span class="req">*</span>资产名称</label><input id="ft_name"></div>
<div class="fg"><label>规格型号</label><input id="ft_spec"></div>
<div class="fg"><label><span class="req">*</span>资产类别一级</label><select id="ft_l1" onchange="onFTL1()"><option value="">请选择</option><option>无形资产</option><option>固定资产</option></select></div>
<div class="fg"><label><span class="req">*</span>资产类别二级</label><select id="ft_l2"><option value="">请先选择一级</option></select></div>
<div class="fg"><label>取得方式</label><input id="ft_obtain" value="自研" readonly></div>
<div class="fg"><label><span class="req">*</span>项目编号</label><input id="ft_proj" readonly class="ro-green"></div>
<div class="fg"><label><span class="req">*</span>公司名称</label><input id="ft_company" value="海洋科技"></div>
<div class="fg"><label>使用部门</label><input id="ft_dept"></div>
<div class="fg"><label>使用状态</label><select id="ft_use"><option>在用</option><option>闲置</option><option>报废</option></select></div>
</div>
<div class="sec">价值与摊销信息</div><div class="fg2">
<div class="fg"><label><span class="req">*</span>加计扣除原值</label><input id="ft_deduction" type="number" readonly class="ro-green"></div>
<div class="fg"><label>会计原值</label><input id="ft_orig" type="number"></div>
<div class="fg"><label><span class="req">*</span>残值率(%)</label><input id="ft_res" type="number" value="5"></div>
<div class="fg"><label><span class="req">*</span>税务摊销期限(月)</label><input id="ft_tlife" type="number" placeholder="如60"></div>
<div class="fg"><label><span class="req">*</span>税务摊销方法</label><select id="ft_meth"><option value="">请选择</option><option>直线法</option><option>双倍余额递减法</option><option>年数总和法</option></select></div>
<div class="fg"><label>开始使用日期</label><input id="ft_date" type="date"></div>
<div class="fg"><label>税会折旧摊销差异</label><select id="ft_diff"><option>是</option><option>否</option></select></div>
<div class="fg"><label>用途分类</label><select id="ft_purpose"><option>直接研发</option><option>间接研发</option></select></div>
</div>
<div class="fg"><label>备注</label><input id="ft_rmk" style="width:100%"></div>
</div>
<div class="ml-f"><button class="btn btn-o" onclick="closeMo('moTransfer')">取消</button><button class="btn btn-p" onclick="saveTransfer()">保存并生成摊销计划</button></div>
</div>
</div>

<!-- 摊销明细弹窗 -->
<div class="mo" id="moAmortDetail"><div class="ml" style="max-width:1080px">
<div class="ml-h"><h3 id="amortDetailTitle">摊销明细</h3><button class="ml-x" onclick="closeMo('moAmortDetail')">✕</button></div>
<div class="ml-b">
<div class="fg2" style="margin-bottom:12px">
<div class="fg"><label>资产编号</label><input id="ad_aid" readonly class="ro-green"></div>
<div class="fg"><label>资产名称</label><input id="ad_aname" readonly class="ro-green"></div>
<div class="fg"><label>加计扣除原值</label><input id="ad_deduction" readonly class="ro-green"></div>
<div class="fg"><label>残值率</label><input id="ad_res" readonly class="ro-green"></div>
<div class="fg"><label>税务摊销期限</label><input id="ad_tlife" readonly class="ro-green"></div>
<div class="fg"><label>税务摊销方法</label><input id="ad_meth" readonly class="ro-green"></div>
</div>
<div class="sec">摊销明细记录</div>
<div class="bg" style="margin-bottom:12px"><button class="btn btn-p" onclick="genNextAmort()">⚡ 生成下一期摊销</button><button class="btn btn-o" onclick="genAllAmort()">📋 生成全部摊销计划</button></div>
<div class="tw"><table><thead><tr>
<th>摊销期间</th><th>期初净值</th><th>本期摊销额</th><th>累计已摊销</th><th>期末净值</th><th>状态</th><th>操作</th>
</tr></thead><tbody id="amortDetailTb"></tbody></table></div>
</div>
<div class="ml-f"><button class="btn btn-o" onclick="closeMo('moAmortDetail')">关闭</button></div>
</div>
</div>

</body>
</html>
